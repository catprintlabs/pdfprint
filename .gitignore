# Build artifacts — binaries are built in CI and published to GitHub Releases
# (see .github/workflows/release.yml), never committed.
/pdfprint
/pdfprint.exe
/stamp
/stamp.exe
/dist/
*.out

# Vendored Ghostscript for bundling (regenerate with scripts/vendor-gs.ps1)
/vendor/

# OS junk
.DS_Store

# Local scratch
/scratch/
*.pcl
*.ps
!testdata/*.ps

# Regenerable smoke-test outputs (pdfprint --output results & gs proof renders)
testdata/*.out.*
testdata/*.proof.png

# Generated test fixture (regenerate with `make fixture`)
/testdata/hello.pdf
